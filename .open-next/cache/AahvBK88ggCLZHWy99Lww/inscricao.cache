/logo.png\"/><div class=\"absolute inset-0 bg-primary/20 blur-3xl -z-10 animate-pulse\"></div></div></div><div class=\"glass-card rounded-full px-8 py-3 inline-block border border-primary/20\" style=\"opacity:0;transform:scale(0.8)\"><span class=\"text-primary font-semibold text-lg\">Faça sua inscrição no Querido Camp</span></div><div class=\"flex justify-center space-x-4 mt-12\" style=\"opacity:0;transform:scale(0)\"><div class=\"glass-card w-16 h-1 rounded-full bg-primary/30\"></div><div class=\"glass-card w-8 h-8 rounded-full flex items-center justify-center border border-primary/20\"><div class=\"w-3 h-3 bg-primary rounded-full animate-pulse\"></div></div><div class=\"glass-card w-16 h-1 rounded-full bg-primary/30\"></div></div></div></div><div class=\"absolute bottom-0 left-0 right-0\"><svg viewBox=\"0 0 1200 120\" class=\"w-full h-20 fill-current text-primary/10\"><path d=\"M0,60 C300,120 900,0 1200,60 L1200,120 L0,120 Z\"></path></svg></div></div><section class=\"py-16 bg-gradient-to-b from-dark to-dark/80 min-h-screen\"><div class=\"container mx-auto px-4\"><div class=\"max-w-4xl mx-auto\"><div class=\"mb-8\" style=\"opacity:0;transform:translateY(20px)\"><div class=\"relative group glass-gold glass-hover glass-shine rounded-2xl overflow-hidden \" style=\"opacity:0;transform:translateY(20px)\"><div class=\"absolute inset-0 bg-gradient-to-br from-white/10 via-transparent to-transparent opacity-50 rounded-2xl pointer-events-none\"></div><div class=\"relative z-10 h-full\"><div class=\"p-6 bg-gradient-to-br from-primary/10 to-accent/10 border border-primary/20 rounded-lg\"><h3 class=\"text-xl font-bold text-primary mb-4 flex items-center gap-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-alert w-6 h-6\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><line x1=\"12\" x2=\"12\" y1=\"8\" y2=\"12\"></line><line x1=\"12\" x2=\"12.01\" y1=\"16\" y2=\"16\"></line></svg>Informações de Pagamento</h3><div class=\"space-y-2 text-light\"><p class=\"font-semibold text-lg text-primary\">PIX para Inscrição</p><p><span class=\"font-semibold\">Chave PIX (CNPJ):</span> 63.790.373/0001-23</p><p><span class=\"font-semibold\">Banco:</span> Inter</p><p><span class=\"font-semibold\">Nome Fantasia:</span> Querido Camp</p><p><span class=\"font-semibold\">Titular:</span> Denis Lima</p><p class=\"text-xl font-bold text-primary mt-2\">Valor: R$ 75,00</p></div></div></div><div class=\"absolute -inset-0.5 bg-gradient-to-r from-gold/20 via-gold/40 to-gold/20 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 blur-sm -z-10\"></div></div></div><div style=\"opacity:0;transform:translateY(20px)\"><div class=\"relative group glass-gold glass-hover glass-shine rounded-2xl overflow-hidden \" style=\"opacity:0;transform:translateY(20px)\"><div class=\"absolute inset-0 bg-gradient-to-br from-white/10 via-transparent to-transparent opacity-50 rounded-2xl pointer-events-none\"></div><div class=\"relative z-10 h-full\"><form class=\"p-8 space-y-6\"><h2 class=\"text-2xl font-bold text-primary mb-6\">Dados do Participante</h2><div><label for=\"email\" class=\"block text-light font-semibold mb-2\">E-mail *</label><input type=\"email\" id=\"email\" required=\"\" class=\"w-full px-4 py-3 bg-dark/50 border border-primary/30 rounded-lg text-light focus:outline-none focus:border-primary transition-colors\" placeholder=\"seu@email.com\" name=\"email\" value=\"\"/></div><div><label for=\"nomeCompleto\" class=\"block text-light font-semibold mb-2\">Nome Completo *</label><input type=\"text\" id=\"nomeCompleto\" required=\"\" class=\"w-full px-4 py-3 bg-dark/50 border border-primary/30 rounded-lg text-light focus:outline-none focus:border-primary transition-colors\" placeholder=\"Seu nome completo\" name=\"nomeCompleto\" value=\"\"/></div><div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\"><div><label for=\"idade\" class=\"block text-light font-semibold mb-2\">Idade *</label><input type=\"number\" id=\"idade\" required=\"\" min=\"16\" class=\"w-full px-4 py-3 bg-dark/50 border border-primary/30 rounded-lg text-light focus:outline-none focus:border-primary transition-colors\" placeholder=\"18\" name=\"idade\" value=\"\"/></div><div><label for=\"dataNascimento\" class=\"block text-light font-semibold mb-2\">Data de Nascimento *</label><input type=\"date\" id=\"dataNascimento\" required=\"\" class=\"w-full px-4 py-3 bg-dark/50 border border-primary/30 rounded-lg text-light focus:outline-none focus:border-primary transition-colors\" name=\"dataNascimento\" value=\"\"/></div></div><div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\"><div><label for=\"estado\" class=\"block text-light font-semibold mb-2\">Estado *</label><input type=\"text\" id=\"estado\" required=\"\" class=\"w-full px-4 py-3 bg-dark/50 border border-primary/30 rounded-lg text-light focus:outline-none focus:border-primary transition-colors\" placeholder=\"Sergipe\" name=\"estado\" value=\"\"/></div><div><label for=\"cidade\" class=\"block text-light font-semibold mb-2\">Cidade *</label><input type=\"text\" id=\"cidade\" required=\"\" class=\"w-full px-4 py-3 bg-dark/50 border border-primary/30 rounded-lg text-light focus:outline-none focus:border-primary transition-colors\" placeholder=\"Aracaju\" name=\"cidade\" value=\"\"/></div></div><div><label for=\"nick\" class=\"block text-light font-semibold mb-2\">Nick (o mesmo da plataforma Faceit) *</label><input type=\"text\" id=\"nick\" required=\"\" class=\"w-full px-4 py-3 bg-dark/50 border border-primary/30 rounded-lg text-light focus:outline-none focus:border-primary transition-colors\" placeholder=\"Seu nickname\" name=\"nick\" value=\"\"/></div><div class=\"space-y-4\"><div><label for=\"faceitLink\" class=\"block text-light font-semibold mb-2\">Link do perfil Faceit *</label><input type=\"url\" id=\"faceitLink\" req