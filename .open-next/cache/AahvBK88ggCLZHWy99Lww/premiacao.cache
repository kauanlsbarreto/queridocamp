src=\"/logo.png\"/><div class=\"absolute inset-0 bg-primary/20 blur-3xl -z-10 animate-pulse\"></div></div></div><div class=\"glass-card rounded-full px-8 py-3 inline-block border border-primary/20\" style=\"opacity:0;transform:scale(0.8)\"><span class=\"text-primary font-semibold text-lg\">Confira os prêmios do Querido Camp</span></div><div class=\"flex justify-center space-x-4 mt-12\" style=\"opacity:0;transform:scale(0)\"><div class=\"glass-card w-16 h-1 rounded-full bg-primary/30\"></div><div class=\"glass-card w-8 h-8 rounded-full flex items-center justify-center border border-primary/20\"><div class=\"w-3 h-3 bg-primary rounded-full animate-pulse\"></div></div><div class=\"glass-card w-16 h-1 rounded-full bg-primary/30\"></div></div></div></div><div class=\"absolute bottom-0 left-0 right-0\"><svg viewBox=\"0 0 1200 120\" class=\"w-full h-20 fill-current text-primary/10\"><path d=\"M0,60 C300,120 900,0 1200,60 L1200,120 L0,120 Z\"></path></svg></div></div><section class=\"py-16 bg-gradient-to-b from-black to-gray-900\"><div class=\"container mx-auto px-4\"><h2 class=\"text-3xl font-bold text-gold mb-10 text-center\" style=\"opacity:0;transform:translateY(20px)\">Premiação em Dinheiro</h2><div class=\"max-w-4xl mx-auto\"><div class=\"grid grid-cols-1 md:grid-cols-2 gap-8\"><div class=\"relative group glass-gold glass-hover glass-shine rounded-2xl overflow-hidden \" style=\"opacity:0;transform:translateY(20px)\"><div class=\"absolute inset-0 bg-gradient-to-br from-white/10 via-transparent to-transparent opacity-50 rounded-2xl pointer-events-none\"></div><div class=\"relative z-10 h-full\"><div class=\"p-8 text-center\"><div class=\"text-5xl font-bold text-gold mb-4\">1º Lugar</div><div class=\"text-4xl font-bold text-white mb-6\">R$ 1.000,00</div><div class=\"bg-gold/20 p-6 rounded-full inline-block flex items-center justify-center mb-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\