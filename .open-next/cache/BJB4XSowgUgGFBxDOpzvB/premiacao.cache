sparent\" src=\"/logo.png\"/><div class=\"absolute inset-0 bg-primary/20 blur-3xl -z-10 animate-pulse\"></div></div></div><div class=\"glass-card rounded-full px-8 py-3 inline-block border border-primary/20\" style=\"opacity:0;transform:scale(0.8)\"><span class=\"text-primary font-semibold text-lg\">Confira os prêmios do Querido Camp</span></div><div class=\"flex justify-center space-x-4 mt-12\" style=\"opacity:0;transform:scale(0)\"><div class=\"glass-card w-16 h-1 rounded-full bg-primary/30\"></div><div class=\"glass-card w-8 h-8 rounded-full flex items-center justify-center border border-primary/20\"><div class=\"w-3 h-3 bg-primary rounded-full animate-pulse\"></div></div><div class=\"glass-card w-16 h-1 rounded-full bg-primary/30\"></div></div></div></div><div class=\"absolute bottom-0 left-0 right-0\"><svg viewBox=\"0 0 1200 120\" class=\"w-full h-20 fill-current text-primary/10\"><path d=\"M0,60 C300,120 900,0 1200,60 L1200,120 L0,120 Z\"></path></svg></div></div><section class=\"py-16 bg-gradient-to-b from-black to-gray-900\"><div class=\"container mx-auto px-4\"><h2 class=\"text-3xl font-bold text-gold mb-10 text-center\" style=\"opacity:0;transform:translateY(20px)\">Premiação em Dinheiro</h2><div class=\"max-w-4xl mx-auto\"><div class=\"grid grid-cols-1 md:grid-cols-2 gap-8\"><div class=\"relative group glass-gold glass-hover glass-shine rounded-2xl overflow-hidden \" style=\"opacity:0;transform:translateY(20px)\"><div class=\"absolute inset-0 bg-gradient-to-br from-white/10 via-transparent to-transparent opacity-50 rounded-2xl pointer-events-none\"></div><div class=\"relative z-10 h-full\"><div class=\"p-8 text-center\"><div class=\"text-5xl font-bold text-gold mb-4\">1º Lugar</div><div class=\"text-4xl font-bold text-white mb-6\">R$ 1.000,00</div><div class=\"bg-gold/20 p-6 rounded-full inline-block flex items-center justify-center mb-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-trophy text-gold h-20 w-20\"><path d=\"M6 9H4.5a2.5 2.5 0 0 1 0-5H6\"></path><path d=\"M18 9h1.5a2.5 2.5 0 0 0 0-5H18\"></path><path d=\"M4 22h16\"></path><path d=\"M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22\"></path><path d=\"M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22\"></path><path d=\"M18 2H6v7a6 6 0 0 0 12 0V2Z\"></path></svg></div><p class=\"text-gray-300 text-lg\">Troféu de Campeão + Premiação em Dinheiro</p></div></div><div class=\"absolute -inset-0.5 bg-gradient-to-r from-gold/20 via-gold/40 to-gold/20 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 blur-sm -z-10\"></div></div><div class=\"relative group glass-gold glass-hover glass-shine rounded-2xl overflow-hidden \" style=\"opacity:0;transform:translateY(20px)\"><div class=\"absolute inset-0 bg-gradient-to-br from-white/10 via-transparent to-transparent opacity-50 rounded-2xl pointer-events-none\"></div><div class=\"relative z-10 h-full\"><div class=\"p-8 text-center\"><h3 class=\"text-3xl font-bold text-gold mb-6\">MVP do Campeonato</h3><div class=\"text-4xl font-bold text-white mb-6\">R$ 250,00</div><div class=\"bg-gold/20 p-6 rounded-full inline-block flex items-center justify-center mb-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-award text-gold h-20 w-20\"><path d=\"m15.477 12.89 1.515 8.526a.5.5 0 0 1-.81.47l-3.58-2.687a1 1 0 0 0-1.197 0l-3.586 2.686a.5.5 0 0 1-.81-.469l1.514-8.526\"></path><circle cx=\"12\" cy=\"8\" r=\"6\"></circle></svg></div><p class=\"text-gray-300 text-lg\">Troféu de MVP + Premiação em Skin</p></div></div><div class=\"absolute -inset-0.5 bg-gradient-to-r from-gold/20 via-gold/40 to-gold/20 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 blur-sm -z-10\"></div></div></div><div class=\"mt-12 text-center\"><div class=\"relative group glass-gold glass-hover glass-shine rounded-2xl overflow-hidden \" style=\"opacity:0;transform:translateY(20px)\"><div class=\"absolute inset-0 bg-gradient-to-br from-white/10 via-transparent to-transparent opacity-50 rounded-2xl pointer-events-none\"></div><div class=\"relative z-10 h-full\"><div class=\"p-8\"><h3 class=\"text-2xl font-bold text-gold mb-6\">Premiação Total: R$ 1.500,00</h3><p class=\"text-white text-lg mb-4\">Além da premiação em dinheiro, todos os participantes receberão:</p><ul class=\"text-gray-300 space-y-2 max-w-2xl mx-auto\"><li>• Experiência em finais presenciais em LAN</li><li>• Reconhecimento no cenário competitivo de Sergipe</li><li>• Oportunidade de networking com outros jogadores</li></ul></div></div><div class=\"absolute -inset-0.5 bg-gradient-to-r from-gold/20 via-gold/40 to-gold/20 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 blur-sm -z-10\"></div></div></div></div></div></section><section class=\"py-16 bg-black\"><div class=\"container mx-auto px-4\"><h2 class=\"text-3xl font-bold text-gold mb-10 text-center\" style=\"opacity:0;transform:translateY(20px)\">Reconhecimentos Especiais</h2><div class=\"max-w-4xl mx-auto\"><div class=\"relative group glass-gold glass-hover glass-shine rounded-2xl overflow-hidden \" style=\"opacity:0;transform:translateY(20px)\"><div class=\"absolute inset-0 bg-gradient-to-br from-white/10 via-transparent to-transparent opacity-50 rounded-2xl pointer-events-none\"></div><div class=\"relative z-10 h-full\"><div class=\"p-8\"><h3 class=\"text-2xl font-bold text-gold mb-6 text-center\">MELHORES DO CAMPEONATO</h3><p class=\"text-white text-center mb-8\">Reconhecimento especial para os destaques do campeonato em diferentes categorias</p><div class=\"grid grid-cols-2 md:grid-cols-3 gap-6\"><div class=\"bg-gray-800 p-6 rounded-lg text-center hover:bg-gray-7